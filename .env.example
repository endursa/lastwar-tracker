# Last War Kill Tracker - Environment Variables
# Copy this to .env and fill in your values

# Your Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Your Google Sheet ID from the sheet URL
# Example: https://docs.google.com/spreadsheets/d/THIS_PART_IS_THE_ID/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here
